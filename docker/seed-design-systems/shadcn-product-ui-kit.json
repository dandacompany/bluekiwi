    "Table": {
      "framework": "shadcn",
      "style_system": "HTML table + Tailwind CSS",
      "description": "Dense data table with selectable rows and status cells.",
      "props": [
        { "name": "rows", "type": "Array<Record<string, unknown>>", "description": "Visible rows" }
      ],
      "variants": ["default", "selectable", "compact", "loading"],
      "states": ["default", "hover", "focus-visible", "selected", "empty", "loading", "error"],
      "classes": ["w-full", "text-sm", "border-separate", "border-spacing-0", "data-[selected=true]:bg-muted"],
      "install": ["npx shadcn@latest add table checkbox"],
      "preview": {
        "html": "<table class=\"kit-table\"><thead><tr><th>Name</th><th>Status</th></tr></thead><tbody><tr><td>Product Kit</td><td>Published</td></tr></tbody></table>",
        "css": ".kit-table{width:100%;border-collapse:collapse;font:13px Inter}.kit-table th,.kit-table td{border-bottom:1px solid #CBD5E1;padding:10px;text-align:left}.kit-table th{color:#64748B;font-weight:700}"
      },
