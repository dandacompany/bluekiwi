      "framework": "shadcn",
      "style_system": "Radix Dropdown Menu + Tailwind CSS",
      "description": "Contextual action menu for compact secondary commands.",
      "props": [
        { "name": "items", "type": "Array<MenuItem>", "description": "Menu actions" }
      ],
      "variants": ["default", "with-icons", "danger-zone"],
      "states": ["closed", "open", "hover", "focus-visible", "disabled"],
      "classes": ["min-w-40", "rounded-md", "border", "bg-popover", "p-1"],
      "dependencies": ["@radix-ui/react-dropdown-menu", "lucide-react"],
      "install": ["npx shadcn@latest add dropdown-menu"],
      "preview": {
        "html": "<div class=\"kit-menu\"><button>Duplicate</button><button>Export</button><button class=\"danger\">Delete</button></div>",
        "css": ".kit-menu{width:180px;border:1px solid #CBD5E1;border-radius:8px;background:#fff;padding:4px;font:14px Inter}.kit-menu button{display:block;width:100%;border:0;background:transparent;text-align:left;padding:8px;border-radius:6px}.kit-menu .danger{color:#DC2626}"
