      "preview": {
        "html": "<section class=\"kit-dialog\"><h3>Import package?</h3><p>Related design system found.</p><button>Continue</button></section>",
        "css": ".kit-dialog{width:320px;border:1px solid #CBD5E1;border-radius:8px;background:#fff;padding:18px;font:14px Inter;box-shadow:0 8px 24px rgba(15,23,42,.08)}.kit-dialog h3{margin:0 0 6px}.kit-dialog p{color:#64748B}.kit-dialog button{height:34px;border:0;border-radius:6px;background:#2563EB;color:#fff;padding:0 12px}"
      },
