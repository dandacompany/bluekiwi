      "variants": ["default", "compact", "underline"],
      "states": ["default", "hover", "focus-visible", "active", "disabled"],
      "classes": ["inline-flex", "rounded-md", "bg-muted", "data-[state=active]:bg-background"],
      "dependencies": ["@radix-ui/react-tabs"],
      "install": ["npx shadcn@latest add tabs"],
      "preview": {
        "html": "<div class=\"kit-tabs\"><button class=\"active\">Colors</button><button>Components</button><button>Assets</button></div>",
        "css": ".kit-tabs{display:inline-flex;gap:2px;border-radius:6px;background:#F1F5F9;padding:3px;font:13px Inter}.kit-tabs button{border:0;border-radius:5px;background:transparent;padding:7px 10px}.kit-tabs .active{background:#fff;box-shadow:0 1px 2px rgba(15,23,42,.06)}"
