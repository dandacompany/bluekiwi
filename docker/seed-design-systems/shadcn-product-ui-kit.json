      "dependencies": ["@radix-ui/react-switch"],
      "install": ["npx shadcn@latest add switch"],
      "preview": {
        "html": "<label class=\"kit-switch-row\"><span>Active design system</span><span class=\"kit-switch\"><i></i></span></label>",
        "css": ".kit-switch-row{display:flex;justify-content:space-between;align-items:center;font:14px Inter}.kit-switch{width:36px;height:20px;border-radius:999px;background:#2563EB;padding:2px}.kit-switch i{display:block;width:16px;height:16px;border-radius:50%;background:#fff;margin-left:16px}"
