{
  "title": "shadcn Product UI Kit",
  "slug": "shadcn-product-ui-kit",
  "description": "Reference-grade shadcn/Tailwind design system for product dashboards, forms, settings, and agent-facing admin tools.",
  "version": "1.0",
  "category": "Reference Kit",
  "surface": "web",
  "schema": {
    "version": "1.0",
    "mediums": ["web", "app"],
    "archetype": "product-ui-component-kit",
    "supports": ["react", "tailwindcss", "shadcn-ui", "html-css"],
    "entrypoints": {
      "agent_document": "DESIGN.md",
      "split_tokens": [
        "tokens/colors.json",
        "tokens/typography.json",
        "tokens/components.json"
      ],
      "implementation": "adapters.json"
    }
  },
  "tokens": {
    "spacing": {
      "1": 4,
      "2": 8,
      "3": 12,
      "4": 16,
      "5": 20,
      "6": 24,
      "8": 32,
      "section": 48
    },
    "radius": {
      "control": 6,
      "card": 8,
      "popover": 8,
      "modal": 8
    },
    "shadow": {
      "none": "none",
      "sm": "0 1px 2px rgba(15,23,42,.06)",
      "md": "0 8px 24px rgba(15,23,42,.08)"
    },
    "motion": {
      "durationFast": "120ms",
      "durationBase": "180ms",
      "easingStandard": "cubic-bezier(.2,.8,.2,1)"
    },
    "layout": {
      "sidebar": 264,
      "contentMax": 1280,
      "toolbar": 48
    }
  },
  "color_tokens": {
    "background": "#F8FAFC",
    "foreground": "#0F172A",
    "card": "#FFFFFF",
    "cardForeground": "#0F172A",
    "popover": "#FFFFFF",
    "popoverForeground": "#0F172A",
    "primary": "#2563EB",
    "primaryForeground": "#FFFFFF",
    "secondary": "#E2E8F0",
    "secondaryForeground": "#1E293B",
    "muted": "#F1F5F9",
    "mutedForeground": "#64748B",
    "accent": "#14B8A6",
    "accentForeground": "#042F2E",
    "destructive": "#DC2626",
    "destructiveForeground": "#FFFFFF",
    "border": "#CBD5E1",
    "input": "#CBD5E1",
    "ring": "#2563EB",
    "success": "#16A34A",
    "warning": "#CA8A04",
    "info": "#0891B2"
  },
  "typography_tokens": {
    "display": "Inter, Pretendard, system-ui, sans-serif",
    "heading": "Inter, Pretendard, system-ui, sans-serif",
    "body": "Inter, Pretendard, system-ui, sans-serif",
    "label": "Inter, Pretendard, system-ui, sans-serif",
    "caption": "Inter, Pretendard, system-ui, sans-serif",
    "mono": "JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, monospace",
