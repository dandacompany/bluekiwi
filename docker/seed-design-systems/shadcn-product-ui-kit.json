    "Badge": {
      "framework": "shadcn",
      "style_system": "shadcn/ui + Tailwind CSS",
      "description": "Compact status or metadata label.",
      "props": [
        { "name": "variant", "type": "default | secondary | outline | destructive | success | warning", "description": "Semantic tone" }
      ],
      "variants": ["default", "secondary", "outline", "success", "warning", "destructive"],
      "states": ["default", "hover", "focus-visible", "disabled"],
      "classes": ["inline-flex", "rounded-md", "px-2", "py-0.5", "text-xs", "font-medium"],
      "install": ["npx shadcn@latest add badge"],
      "preview": {
        "html": "<div class=\"kit-badges\"><span>Published</span><span class=\"warn\">Needs lint</span></div>",
        "css": ".kit-badges{display:flex;gap:6px}.kit-badges span{border-radius:6px;background:#DCFCE7;color:#166534;padding:3px 8px;font:600 12px Inter}.kit-badges .warn{background:#FEF3C7;color:#92400E}"
      },
      "usage": "Use for metadata, not primary actions. Prefer semantic color names over arbitrary colors."
    },
    "Alert": {
      "framework": "shadcn",
      "style_system": "shadcn/ui + Tailwind CSS",
      "description": "Inline message for validation, warnings, and operational status.",
      "props": [
        { "name": "variant", "type": "default | destructive | warning | success", "description": "Alert tone" }
      ],
      "variants": ["default", "info", "success", "warning", "destructive"],
      "states": ["default", "focus-visible", "dismissible"],
      "classes": ["rounded-lg", "border", "p-4", "text-sm"],
      "install": ["npx shadcn@latest add alert"],
      "preview": {
        "html": "<div class=\"kit-alert\"><strong>Related system found</strong><p>Importing as a new version is recommended.</p></div>",
        "css": ".kit-alert{border:1px solid #0891B2;border-radius:8px;background:#ECFEFF;color:#164E63;padding:12px;font:14px Inter}.kit-alert p{margin:4px 0 0}"
      },
      "usage": "Use near the relevant task. Keep text actionable and specific."
    },
    "Toast": {
      "framework": "shadcn",
      "style_system": "Sonner or shadcn Toast + Tailwind CSS",
      "description": "Transient non-blocking feedback after save, copy, import, or export.",
      "props": [
        { "name": "type", "type": "success | error | info", "description": "Feedback tone" }
      ],
