      "h1": "32px/1.2",
      "h2": "24px/1.25",
      "h3": "18px/1.35",
      "body": "14px/1.6",
      "caption": "12px/1.45"
    }
  },
  "component_tokens": {
    "Button": {
      "framework": "shadcn",
      "style_system": "shadcn/ui + Tailwind CSS",
      "description": "Command button for primary, secondary, destructive, and icon-only actions.",
      "props": [
        { "name": "variant", "type": "default | secondary | outline | ghost | destructive", "description": "Visual emphasis" },
        { "name": "size", "type": "sm | default | lg | icon", "description": "Control density" }
      ],
      "variants": ["default", "secondary", "outline", "ghost", "destructive", "icon"],
      "states": ["default", "hover", "focus-visible", "active", "disabled", "loading"],
      "classes": ["inline-flex", "h-9", "rounded-md", "px-3", "font-medium", "focus-visible:ring-2"],
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority", "lucide-react"],
      "install": ["npx shadcn@latest add button"],
      "preview": {
        "html": "<div class=\"kit-row\"><button class=\"kit-button\">Save changes</button><button class=\"kit-button kit-button-outline\">Cancel</button></div>",
        "css": ".kit-row{display:flex;gap:8px;align-items:center}.kit-button{height:36px;border:1px solid #2563EB;border-radius:6px;background:#2563EB;color:#fff;padding:0 12px;font:600 14px Inter}.kit-button-outline{background:#fff;color:#0F172A;border-color:#CBD5E1}"
      },
      "react": "import { Button } from \"@/components/ui/button\";\n\nexport function SaveActions() {\n  return <div className=\"flex gap-2\"><Button>Save changes</Button><Button variant=\"outline\">Cancel</Button></div>;\n}",
      "usage": "Use one primary button per decision group. Use icon-only buttons only for familiar commands with accessible labels."
    },
    "Input": {
      "framework": "shadcn",
      "style_system": "shadcn/ui + Tailwind CSS",
      "description": "Single-line text input with visible label, helper text, and validation state.",
      "props": [
        { "name": "aria-invalid", "type": "boolean", "description": "Marks invalid state" },
        { "name": "placeholder", "type": "string", "description": "Short example value" }
      ],
      "variants": ["default", "with-icon", "invalid", "readonly"],
      "states": ["default", "hover", "focus-visible", "disabled", "error"],
      "classes": ["h-9", "rounded-md", "border", "px-3", "focus-visible:ring-2", "aria-invalid:border-destructive"],
      "install": ["npx shadcn@latest add input label"],
      "preview": {
        "html": "<label class=\"kit-field\"><span>Project name</span><input class=\"kit-input\" placeholder=\"Agent Console\" /></label>",
        "css": ".kit-field{display:grid;gap:6px;font:600 13px Inter;color:#0F172A}.kit-input{height:36px;border:1px solid #CBD5E1;border-radius:6px;padding:0 10px;font:14px Inter}"
      },
      "usage": "Always include a persistent label. Do not rely on placeholder text as the only label."
    },
    "Textarea": {
      "framework": "shadcn",
      "style_system": "shadcn/ui + Tailwind CSS",
      "description": "Multi-line input for prompts, descriptions, and notes.",
      "props": [
        { "name": "rows", "type": "number", "description": "Default visible height" }
      ],
      "variants": ["default", "invalid", "monospace"],
      "states": ["default", "hover", "focus-visible", "disabled", "error"],
      "classes": ["min-h-24", "rounded-md", "border", "p-3", "focus-visible:ring-2"],
      "install": ["npx shadcn@latest add textarea"],
      "preview": {
        "html": "<textarea class=\"kit-textarea\" placeholder=\"Describe the agent behavior\"></textarea>",
        "css": ".kit-textarea{width:100%;min-height:96px;border:1px solid #CBD5E1;border-radius:6px;padding:10px 12px;font:14px/1.5 Inter;resize:vertical}"
      },
      "usage": "Use for user-authored content. Keep code or machine values in monospace variant."
    },
    "Select": {
      "framework": "shadcn",
      "style_system": "Radix Select + Tailwind CSS",
      "description": "Dropdown select for bounded option sets.",
      "props": [
        { "name": "options", "type": "Array<{ label: string; value: string }>", "description": "Available choices" }
      ],
      "variants": ["default", "compact", "invalid"],
      "states": ["default", "hover", "focus-visible", "open", "disabled", "error"],
      "classes": ["h-9", "rounded-md", "border", "bg-background", "data-[state=open]:ring-2"],
      "dependencies": ["@radix-ui/react-select"],
      "install": ["npx shadcn@latest add select"],
      "preview": {
        "html": "<button class=\"kit-select\">Published <span>⌄</span></button>",
        "css": ".kit-select{height:36px;min-width:180px;border:1px solid #CBD5E1;border-radius:6px;background:#fff;padding:0 10px;display:flex;justify-content:space-between;align-items:center;font:14px Inter}"
      },
      "usage": "Use when choices are known and fewer than about 20. Prefer search/combobox for long lists."
    },
    "Checkbox": {
      "framework": "shadcn",
      "style_system": "Radix Checkbox + Tailwind CSS",
      "description": "Boolean or multi-select option control.",
      "props": [
        { "name": "checked", "type": "boolean | indeterminate", "description": "Current check state" }
      ],
      "variants": ["default", "indeterminate", "invalid"],
      "states": ["default", "hover", "focus-visible", "checked", "indeterminate", "disabled", "error"],
      "classes": ["size-4", "rounded-sm", "border", "data-[state=checked]:bg-primary"],
      "dependencies": ["@radix-ui/react-checkbox"],
      "install": ["npx shadcn@latest add checkbox"],
      "preview": {
        "html": "<label class=\"kit-check\"><span class=\"kit-checkbox\">✓</span><span>Include component adapters</span></label>",
        "css": ".kit-check{display:flex;gap:8px;align-items:center;font:14px Inter}.kit-checkbox{width:16px;height:16px;border-radius:4px;background:#2563EB;color:#fff;display:grid;place-items:center;font-size:11px}"
      },
      "usage": "Use for independent selections. Do not use checkboxes for mutually exclusive choices."
    },
    "RadioGroup": {
      "framework": "shadcn",
      "style_system": "Radix Radio Group + Tailwind CSS",
      "description": "Mutually exclusive option set.",
      "props": [
        { "name": "value", "type": "string", "description": "Selected option" }
      ],
      "variants": ["default", "card", "segmented"],
      "states": ["default", "hover", "focus-visible", "checked", "disabled", "error"],
      "classes": ["grid", "gap-2", "data-[state=checked]:border-primary"],
      "dependencies": ["@radix-ui/react-radio-group"],
      "install": ["npx shadcn@latest add radio-group"],
      "preview": {
        "html": "<div class=\"kit-radio-group\"><label><span class=\"kit-radio-dot\"></span> Create new</label><label><span></span> New version</label></div>",
        "css": ".kit-radio-group{display:grid;gap:8px;font:14px Inter}.kit-radio-group label{display:flex;gap:8px;align-items:center}.kit-radio-group span{width:16px;height:16px;border:1px solid #CBD5E1;border-radius:999px}.kit-radio-dot{border:5px solid #2563EB!important}"
      },
      "usage": "Use when exactly one choice must be selected. Show the recommended option first when appropriate."
    },
    "Switch": {
      "framework": "shadcn",
      "style_system": "Radix Switch + Tailwind CSS",
      "description": "Immediate on/off preference toggle.",
      "props": [
        { "name": "checked", "type": "boolean", "description": "Current toggle state" }
      ],
      "variants": ["default", "danger"],
      "states": ["default", "hover", "focus-visible", "checked", "disabled"],
